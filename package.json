{
  "name": "lan-jukebox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12 <23"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:web && tsc -p tsconfig.json",
    "build:web": "vite build web --outDir ../dist/public --emptyOutDir",
    "dev:web": "vite web",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p web/tsconfig.json",
    "lint": "eslint . && prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@noble/ciphers": "^1.3.0",
    "fastify": "^5.8.5",
    "pino": "^10.3.1"
  }
}
